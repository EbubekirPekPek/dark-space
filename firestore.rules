rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Üst düzey koleksiyonlar ────────────────────────────────────────────────
    // notes, goals, dailyLogs, skills, todos, clients
    match /{collection}/{docId} {
      // Okuma, güncelleme, silme: kendi dokumanı
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Oluşturma: userId kendi UID'si olmalı
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Müşteri alt koleksiyonları ─────────────────────────────────────────────
    // clients/{clientId}/clientNotes, clients/{clientId}/kpis
    match /clients/{clientId}/{subcoll}/{subDocId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/clients/$(clientId)).data.userId == request.auth.uid;
    }

  }
}
